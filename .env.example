APP_ENV=production
PUBLIC_APP_URL=https://your-render-url.onrender.com
HOST=0.0.0.0
PORT=10000

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_USERS_TABLE=users
SUPABASE_DELETIONS_TABLE=account_deletions

FIREBASE_API_KEY=your-firebase-api-key
FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_APP_ID=your-firebase-app-id
FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id

STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxx
STRIPE_WEEKLY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx
STRIPE_30DAY_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxx

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=PantryPal <your-email@gmail.com>

